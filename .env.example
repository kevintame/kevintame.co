NEXT_PUBLIC_SITE_URL=https://kevintame.co

# Notion integration — used for database-backed pages (album ratings, etc.)
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# Data source IDs — the collection UUID (NOT the database page ID from the URL)
# Find it via the Notion MCP: it's the UUID in collection://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_ALBUMS_DB_ID=...
